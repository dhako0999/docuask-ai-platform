generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Document {
  id         String   @id @default(uuid())
  name       String
  size       Int
  type       String
  s3Key      String
  content    String
  status     String
  uploadedAt DateTime @default(now())
  createdAt  DateTime @default(now())
}
